{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "order-service",
    "Topics": {
      "OrderCreated": "order.created",
      "ShipmentStatusUpdated": "shipment.status.updated",
      "CheckoutConfirmed": "checkout.confirmed",
      "InventoryReserved": "inventory.reserved",
      "InventoryReservationConfirmed": "inventory.reservation.confirmed",
      "InventoryReservationFailed": "inventory.reservation.failed",
      "FulfillmentCapacityReserved": "fulfillment.capacity.reserved",
      "FulfillmentCapacityConfirmed": "fulfillment.capacity.confirmed",
      "FulfillmentCapacityFailed": "fulfillment.capacity.failed",
      "ShipmentCreated": "shipment.created",
      "ShipmentCreationFailed": "shipment.creation.failed"
    }
  }
}
